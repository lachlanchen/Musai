# Optional. Used by scripts/musai_lyricfit_openai.py if you run lyric adaptation.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.5

# Optional. Used by scripts/run_localization_performance_pipeline.py.
# DeepSeek is the default lyric/check provider for the dedicated performance demo.
MUSAI_LYRIC_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-reasoner

# Optional. Hugging Face token may be needed for gated model weights.
HF_TOKEN=

# Optional object storage placeholders for later web/backend work.
S3_ENDPOINT_URL=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=musai-dev

# Optional. Used by Musai Studio chat/worker wrappers.
# The default chat profile is Codex gpt-5.5 medium.
# The default worker profile is Codex gpt-5.5 xhigh.
MUSAI_CODEX_TIMEOUT=240
MUSAI_CODEX_WORKER_TIMEOUT=1800
