  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "l01",
        "start": 17.76,
        "end": 19.96,
        "text": "云在天地间"
      },
      {
        "id": "l02",
        "start": 19.96,
        "end": 23.86,
        "text": "想念像风，靠近你身边"
      },
      {
        "id": "l03",
        "start": 23.86,
        "end": 25.58,
        "text": "望着那么远"
      },
      {
        "id": "l04",
        "start": 25.58,
        "end": 27.94,
        "text": "却像在眼前"
      },
      {
        "id": "l05",
        "start": 27.94,
        "end": 33.16,
        "text": "慢慢地靠近，一点一点"
      },
      {
        "id": "l06",
        "start": 33.16,
        "end": 34.9,
        "text": "穿过云海"
      },
      {
        "id": "l07",
        "start": 35.46,
        "end": 37.38,
        "text": "落进心里面"
      },
      {
        "id": "l08",
        "start": 39.07,
        "end": 40.97,
        "text": "我想了五年"
      },
      {
        "id": "l09",
        "start": 40.97,
        "end": 42.97,
        "text": "来到你身边"
      },
      {
        "id": "l10",
        "start": 42.97,
        "end": 45.21,
        "text": "看清你的容颜"
      },
      {
        "id": "l11",
        "start": 45.21,
        "end": 48.05,
        "text": "隔着山海万千"
      },
      {
        "id": "l12",
        "start": 48.05,
        "end": 50.51,
        "text": "也想和你相见"
      },
      {
        "id": "l13",
        "start": 51.05,
        "end": 52.75,
        "text": "似水流年"
      },
      {
        "id": "l14",
        "start": 54.29,
        "end": 57.63,
        "text": "时光慢慢转"
      },
      {
        "id": "l15",
        "start": 57.63,
        "end": 60.75,
        "text": "越过千年不变"
      },
      {
        "id": "l16",
        "start": 60.75,
        "end": 62.23,
        "text": "云海之间"
      },
      {
        "id": "l17",
        "start": 62.23,
        "end": 64.27,
        "text": "梦也缱绻"
      },
      {
        "id": "l18",
        "start": 64.27,
        "end": 67.69,
        "text": "我把爱写成一条线"
      },
      {
        "id": "l19",
        "start": 67.69,
        "end": 70.61,
        "text": "牵向你的天边"
      },
      {
        "id": "l20",
        "start": 70.61,
        "end": 78.36,
        "text": "我在远方"
      },
      {
        "id": "l21",
        "start": 79.77,
        "end": 82.47,
        "text": "仍想回到你身边"
      }
    ]
  },
