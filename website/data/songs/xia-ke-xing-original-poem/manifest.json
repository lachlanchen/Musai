  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "l01",
        "start": 10.66,
        "end": 14.92,
        "text": "赵客缦胡缨，吴钩霜雪明"
      },
      {
        "id": "l02",
        "start": 16.46,
        "end": 21.2,
        "text": "银鞍照白马，飒沓如流星"
      },
      {
        "id": "l03",
        "start": 22.18,
        "end": 26.78,
        "text": "十步杀一人，千里不留行"
      },
      {
        "id": "l04",
        "start": 26.78,
        "end": 31.66,
        "text": "事了拂衣去，千里不留行"
      },
      {
        "id": "l05",
        "start": 31.66,
        "end": 36.24,
        "text": "事了拂衣去，深藏身与名"
      },
      {
        "id": "l06",
        "start": 39.88,
        "end": 43.94,
        "text": "闲过信陵饮，脱剑膝前横"
      },
      {
        "id": "l07",
        "start": 45.52,
        "end": 49.82,
        "text": "将炙啖朱亥，持觞劝侯嬴"
      },
      {
        "id": "l08",
        "start": 51.0,
        "end": 55.42,
        "text": "三杯吐然诺，五岳倒为轻"
      },
      {
        "id": "l09",
        "start": 55.42,
        "end": 59.9,
        "text": "眼花耳热后，意气素霓生"
      },
      {
        "id": "l10",
        "start": 60.42,
        "end": 65.6,
        "text": "救赵挥金槌，邯郸先震惊"
      },
      {
        "id": "l11",
        "start": 65.6,
        "end": 71.02,
        "text": "千秋二壮士，烜赫大梁城"
      },
      {
        "id": "l12",
        "start": 71.02,
        "end": 75.98,
        "text": "纵死侠骨香，不惭世上英"
      },
      {
        "id": "l13",
        "start": 77.1,
        "end": 81.18,
        "text": "谁能书阁下，白首太玄经"
      },
      {
        "id": "l14",
        "start": 90.5,
        "end": 93.42,
        "text": "白首太玄经"
      }
    ]
  },
