        "id": "l01",
        "start": 28.98,
        "end": 34.62,
        "text": "君不见黄河之水天上来"
      },
      {
        "id": "l02",
        "start": 36.82,
        "end": 42.44,
        "text": "奔流到海不复回"
      },
      {
        "id": "l03",
        "start": 42.44,
        "end": 49.18,
        "text": "君不见高堂明镜悲白发"
      },
      {
        "id": "l04",
        "start": 49.78,
        "end": 53.28,
        "text": "朝如青丝暮成雪"
      },
      {
        "id": "l05",
        "start": 54.38,
        "end": 57.32,
        "text": "人生得意须尽欢"
      },
      {
        "id": "l06",
        "start": 57.92,
        "end": 60.92,
        "text": "莫使金樽空对月"
      },
      {
        "id": "l07",
        "start": 61.52,
        "end": 64.4,
        "text": "天生我材必有用"
      },
      {
        "id": "l08",
        "start": 64.4,
        "end": 68.18,
        "text": "千金散尽还复来"
      },
      {
        "id": "l09",
        "start": 69.68,
        "end": 77.55,
        "text": "烹羊宰牛且为乐，会须一饮三百杯"
      },
      {
        "id": "l10",
        "start": 77.55,
        "end": 80.43,
        "text": "岑夫子，丹丘生"
      },
      {
        "id": "l11",
        "start": 80.43,
        "end": 83.99,
        "text": "将进酒，杯莫停"
      },
      {
        "id": "l12",
        "start": 84.59,
        "end": 87.89,
        "text": "与君歌一曲"
      },
      {
        "id": "l13",
        "start": 87.89,
        "end": 90.99,
        "text": "请君为我倾耳听"
      },
      {
        "id": "l14",
        "start": 91.67,
        "end": 94.53,
        "text": "钟鼓馔玉不足贵"
      },
      {
        "id": "l15",
