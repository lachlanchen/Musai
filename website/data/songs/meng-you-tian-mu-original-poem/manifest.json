        "text": "啊"
      },
      {
        "id": "l01",
        "start": 31.72,
        "end": 35.1,
        "text": "海客谈瀛洲"
      },
      {
        "id": "l02",
        "start": 37.82,
        "end": 41.24,
        "text": "烟涛微茫信难求"
      },
      {
        "id": "l03",
        "start": 41.24,
        "end": 47.34,
        "text": "云霞明灭或可睹"
      },
      {
        "id": "l04",
        "start": 49.48,
        "end": 53.88,
        "text": "天姥连天向天横"
      },
      {
        "id": "l05",
        "start": 54.88,
        "end": 59.46,
        "text": "天台四万八千丈"
      },
      {
        "id": "l06",
        "start": 60.6,
        "end": 65.16,
        "text": "对此欲倒东南倾"
      },
      {
        "id": "l07",
        "start": 66.78,
        "end": 69.02,
        "text": "湖月照我影"
      },
      {
        "id": "l08",
        "start": 69.02,
        "end": 71.22,
        "text": "送我至剡溪"
      },
      {
        "id": "l09",
        "start": 72.1,
        "end": 74.0,
        "text": "谢公宿处"
      },
      {
        "id": "l10",
        "start": 74.0,
        "end": 77.1,
        "text": "渌水荡漾清猿啼"
      },
      {
        "id": "l11",
        "start": 77.1,
        "end": 79.66,
        "text": "脚著谢公屐"
      },
      {
        "id": "l12",
        "start": 79.66,
        "end": 82.48,
        "text": "身登青云梯"
      },
      {
        "id": "l13",
        "start": 83.74,
        "end": 87.42,
        "text": "迷花倚石忽已暝"
      },
      {
        "id": "l14",
        "start": 88.66,
        "end": 92.7,
        "text": "半壁见海日，空中闻天鸡"
      },
      {
        "id": "l15",
        "start": 94.24,
        "end": 99.82,
        "text": "千岩万转路不定，迷花倚石忽已暝"
      },
      {
        "id": "l16",
        "start": 99.82,
        "end": 106.7,
        "text": "熊咆龙吟殷岩泉，栗深林兮惊层巅"
      },
      {
        "id": "l17",
        "start": 106.7,
        "end": 112.5,
        "text": "水澹澹兮生烟"
      },
      {
        "id": "l18",
        "start": 116.4,
        "end": 117.92,
        "text": "列缺霹雳"
      },
      {
        "id": "l19",
        "start": 120.88,
        "end": 122.58,
        "text": "丘峦崩摧"
      },
      {
        "id": "l20",
        "start": 124.08,
        "end": 125.74,
        "text": "洞天石扉"
      },
      {
        "id": "l21",
        "start": 127.3,
        "end": 130.08,
        "text": "訇然中开"
      },
      {
        "id": "l22",
        "start": 132.1,
        "end": 137.96,
        "text": "青冥浩荡不见底，日月照耀金银台"
      },
      {
        "id": "l23",
        "start": 137.96,
        "end": 141.4,
        "text": "霓为衣兮风为马"
      },
      {
        "id": "l24",
        "start": 141.4,
        "end": 146.6,
        "text": "云之君兮纷纷而来下"
      },
      {
        "id": "l25",
        "start": 150.04,
        "end": 152.02,
        "text": "虎鼓瑟兮"
      },
      {
        "id": "l26",
        "start": 152.02,
        "end": 156.98,
        "text": "鸾回车，仙之人兮列如麻"
      },
      {
        "id": "l27",
        "start": 156.98,
        "end": 164.4,
        "text": "忽魂悸以魄动，恍惊起而长嗟"
      },
      {
        "id": "l28",
        "start": 164.4,
        "end": 168.16,
        "text": "惟觉时之枕席"
      },
      {
        "id": "l29",
        "start": 168.16,
        "end": 172.36,
        "text": "世间行乐亦如此"
      },
      {
        "id": "l30",
        "start": 175.86,
        "end": 179.58,
        "text": "古来万事东流水"
      },
