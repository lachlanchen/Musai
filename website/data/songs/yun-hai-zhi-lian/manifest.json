  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "l01",
        "start": 8.0,
        "end": 11.53,
        "text": "天蓝蓝"
      },
      {
        "id": "l02",
        "start": 11.65,
        "end": 15.18,
        "text": "海蓝蓝"
      },
      {
        "id": "l03",
        "start": 15.3,
        "end": 18.83,
        "text": "云在天地间"
      },
      {
        "id": "l04",
        "start": 18.95,
        "end": 23.58,
        "text": "想念像风一样"
      },
      {
        "id": "l05",
        "start": 23.7,
        "end": 28.33,
        "text": "依偎在你身边"
      },
      {
        "id": "l06",
        "start": 28.45,
        "end": 31.98,
        "text": "望着那么远"
      },
      {
        "id": "l07",
        "start": 32.1,
        "end": 35.63,
        "text": "却像在眼前"
      },
      {
        "id": "l08",
        "start": 35.75,
        "end": 39.28,
        "text": "慢慢，慢慢"
      },
      {
        "id": "l09",
        "start": 39.4,
        "end": 42.93,
        "text": "一点，一点"
      },
      {
        "id": "l10",
