    "lines": [
      {
        "id": "line-001",
        "start": 13.17,
        "end": 18.93,
        "sourceText": "In the hush before morning, I hear the city breathe"
      },
      {
        "id": "line-002",
        "start": 18.93,
        "end": 23.99,
        "sourceText": "Hoshi no shita de, kimi to warau, sora e"
      },
      {
        "id": "line-003",
        "start": 23.99,
        "end": 26.93,
        "sourceText": "Yuan fang de feng shuo bie pa"
      },
      {
        "id": "line-004",
        "start": 26.93,
        "end": 29.47,
        "sourceText": "Xin li de guang hui lai"
      },
      {
        "id": "line-005",
        "start": 30.19,
        "end": 32.69,
        "sourceText": "Across the quiet sea"
      },
      {
        "id": "line-006",
        "start": 32.69,
        "end": 34.93,
        "sourceText": "Three voices find a home"
      },
      {
        "id": "line-007",
        "start": 34.93,
        "end": 36.81,
        "sourceText": "We sing under one sky"
      },
      {
        "id": "line-008",
        "start": 36.81,
        "end": 39.89,
        "sourceText": "One sky, one sky"
      },
      {
        "id": "line-009",
        "start": 39.89,
        "end": 43.27,
        "sourceText": "Rang guang ba hei ye da kai"
      },
      {
        "id": "line-010",
        "start": 43.27,
        "end": 46.31,
        "sourceText": "We rise, we rise"
      },
      {
        "id": "line-011",
        "start": 46.31,
        "end": 49.42,
        "sourceText": "Kimi to nara mayowanai"
      },
      {
        "id": "line-012",
        "start": 49.42,
        "end": 51.24,
        "sourceText": "The road is shining"
      },
      {
        "id": "line-013",
        "start": 51.96,
        "end": 54.48,
        "sourceText": "One sky, three lights"
      },
      {
        "id": "line-014",
        "start": 54.48,
        "end": 57.92,
        "sourceText": "One road, one sky"
      },
      {
        "id": "line-015",
