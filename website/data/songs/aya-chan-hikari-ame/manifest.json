  "timeline": {
    "unit": "seconds",
    "lines": [
      {
        "id": "ja-001",
        "start": 0.11,
        "end": 9.69,
        "sourceText": "窓辺で小さなアヤちゃん 雨粒を星に変える"
      },
      {
        "id": "ja-002",
        "start": 11.2,
        "end": 21.82,
        "sourceText": "赤いしっぽそっと揺れて 眠る街へ歌を投げた"
      },
      {
        "id": "ja-003",
        "start": 21.82,
        "end": 30.06,
        "sourceText": "怖くないよ ここにいるよ 胸の鈴が夜を照らす"
      },
      {
        "id": "ja-004",
        "start": 33.22,
        "end": 38.66,
        "sourceText": "きらり きらり アヤちゃん 雲のすきまを走って"
      },
      {
        "id": "ja-005",
        "start": 38.66,
        "end": 47.8,
        "sourceText": "ひとりじゃない ひとりじゃない 夢は消えない"
      },
      {
        "id": "ja-006",
        "start": 47.8,
        "end": 59.26,
        "sourceText": "光の雨で踊ろう 朝が来たら小さな勇気"
      }
    ]
  }
}
